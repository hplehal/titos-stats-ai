# Copy to deploy/.env on the VPS and fill in real values. Never commit .env.
# After copying: `chmod 600 deploy/.env`
#
# POSTGRES_* drive the postgres container directly (compose substitution).
# Everything below is loaded into the api container via env_file.

# ─── Database ──────────────────────────────────────────────────────────
# DATABASE_URL is what the api uses at runtime (async driver).
# DIRECT_URL is an unused-by-Phase-1 sync alias, present for any future
# tooling that wants a non-asyncpg connection (psql-style migrations,
# one-off scripts). Keep the password in sync with POSTGRES_PASSWORD.
DATABASE_URL=postgresql+asyncpg://titos:CHANGE_ME@postgres:5432/titos
DIRECT_URL=postgresql+psycopg://titos:CHANGE_ME@postgres:5432/titos
POSTGRES_USER=titos
POSTGRES_PASSWORD=CHANGE_ME
POSTGRES_DB=titos

# ─── Cloudflare R2 ─────────────────────────────────────────────────────
# Bucket holds raw match videos. R2_PUBLIC_URL is the bucket's r2.dev
# hostname (or a custom domain). Leave blank if not yet provisioned.
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=titos-stats-videos
R2_PUBLIC_URL=

# ─── CORS ──────────────────────────────────────────────────────────────
# Comma-separated. Forward-compat for the Vercel frontend at
# stats.titoscourts.com plus local dev.
CORS_ORIGINS=https://stats.titoscourts.com,http://localhost:3000

# ─── Auth ──────────────────────────────────────────────────────────────
# Shared secret on POST/PATCH/PUT/DELETE. Without this the api returns 503
# on every mutation (fail-closed). Generate per env: `openssl rand -hex 32`.
# Mirror the SAME value into web/.env.local as NEXT_PUBLIC_API_KEY.
API_KEY=CHANGE_ME_GENERATE_FRESH_FOR_PROD

# ─── Anthropic (Phase 3+, unused in Phase 1) ───────────────────────────
ANTHROPIC_API_KEY=
